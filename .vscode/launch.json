{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: authorize",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--log-level",
                "debug",
                "authorize",
                "example.com",
                "www.example.com",
                "--policy-wildcard",
                "--persist-until",
                "2500000000"
            ]
        },
        {
            "name": "Python Debugger: issue",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": [
                "--log-level",
                "debug",
                "issue",
                "example.com",
                "www.example.com",
            ]
        },
    ]
}